# Yerel rent API (Spring Boot 8090). Prod URL’lerini ezer.
# Kullanım: kopyala → `.env.local`  (git’e girmez)
#
#   cp .env.local.example .env.local
#
# `next dev` için local backend:
NEXT_PUBLIC_RENT_API_BASE=http://localhost:8090

# Panelin tarayıcıda açılan kök URL (sonunda / yok). WhatsApp/mail ile tam link üretimi için;
# boş bırakılırsa çoğu yerde `window.location.origin` kullanılır. Prod’da sabit kök isterseniz:
# NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# Proxy modunu yerelde denemek için (ör. prod ile aynı akış):
# NEXT_PUBLIC_RENT_API_BASE=/api/rent
# RENT_API_UPSTREAM=http://localhost:8090
#
# Prod’da doğrudan tarayıcıdan API (proxy yok): NEXT_PUBLIC_RENT_API_BASE=https://rental.algorycode.com

# İsteğe bağlı: yerel AuthService (login rotaları)
# NEXT_PUBLIC_AUTH_BASE=http://localhost:8072/authservice
